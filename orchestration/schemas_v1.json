          "component_id": {
            "title": "Component Id",
            "type": "string"
          },
          "component_name": {
            "title": "Component Name",
            "type": "string"
          },
          "element_type": {
            "title": "Element Type",
            "type": "string"
          },
          "cloud_service": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Cloud Service"
          },
          "trust_boundary": {
            "title": "Trust Boundary",
            "type": "string"
          },
          "stride_entries": {
            "items": {
              "$ref": "#/$defs/STRIDEThreatEntry"
            },
            "title": "Stride Entries",
            "type": "array"
          },
          "llm_reasoning": {
            "title": "Llm Reasoning",
            "type": "string"
          },
          "analyzed_at": {
            "title": "Analyzed At",
            "type": "string"
          }
        },
        "required": [
          "component_id",
          "component_name",
          "element_type",
          "trust_boundary",
          "stride_entries",
          "llm_reasoning",
          "analyzed_at"
        ],
        "title": "ComponentAnalysis",
        "type": "object"
      },
      "STRIDEThreatEntry": {
        "description": "Uma ameaça STRIDE contextualizada para um componente específico.",
        "properties": {
          "category": {
            "enum": [
              "S",
              "T",
              "R",
              "I",
              "D",
              "E"
            ],
            "title": "Category",
            "type": "string"
          },
          "category_name": {
            "default": "",
            "title": "Category Name",
            "type": "string"
          },
          "threat_name": {
            "title": "Threat Name",
            "type": "string"
          },
          "threat_description": {
            "title": "Threat Description",
            "type": "string"
          },
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ],
            "title": "Severity",
            "type": "string"
          },
          "mitigations": {
            "items": {
              "type": "string"
            },
            "title": "Mitigations",
            "type": "array"
          },
          "source": {
            "enum": [
              "taxonomy",
              "enriched",
              "both",
              "llm_only"
            ],
            "title": "Source",
            "type": "string"
          }
        },
        "required": [
          "category",
          "threat_name",
          "threat_description",
          "severity",
          "mitigations",
          "source"
        ],
        "title": "STRIDEThreatEntry",
        "type": "object"
      }
    },
    "description": "Relatório final consolidado de toda a análise STRIDE do diagrama.",
    "properties": {
      "diagram_provider": {
        "title": "Diagram Provider",
        "type": "string"
      },
      "total_components": {
        "title": "Total Components",
        "type": "integer"
      },
      "total_threats": {
        "title": "Total Threats",
        "type": "integer"
      },
      "generated_at": {
        "title": "Generated At",
        "type": "string"
      },
      "component_analyses": {
        "items": {
          "$ref": "#/$defs/ComponentAnalysis"
        },
        "title": "Component Analyses",
        "type": "array"
      },
      "stride_matrix": {
        "additionalProperties": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": "Stride Matrix",
        "type": "object"
      },
      "risk_summary": {
        "additionalProperties": true,
        "title": "Risk Summary",
        "type": "object"
      }
    },
    "required": [
      "diagram_provider",
      "total_components",
      "total_threats",
      "generated_at",
      "component_analyses",
      "stride_matrix",
      "risk_summary"
    ],
    "title": "STRIDEReport",
    "type": "object"
  },

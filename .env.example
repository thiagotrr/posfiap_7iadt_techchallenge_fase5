# Neo4j connection (required for seed script and integration tests)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Crawler settings (optional)
KG_CRAWL_OUTPUT_DIR=data/crawled
KG_CRAWL_DELAY_S=1.5
KG_CRAWL_REQUEST_TIMEOUT_S=30
# Set to false only if local SSL CA chain fails (e.g. corporate proxy on Windows dev)
KG_CRAWL_SSL_VERIFY=true

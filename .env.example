# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# Usado apenas pelo container neo4j para definir usuario/senha iniciais (formato user/senha)
NEO4J_AUTH=neo4j/password

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EXTRACTION_LLM_PROVIDER=anthropic
ANALYSIS_LLM_PROVIDER=anthropic

# --- API ---
ALLOWED_ORIGINS=http://localhost:8501
LOG_LEVEL=INFO

# --- Portas (opcional, defaults abaixo) ---
API_PORT=8000
STREAMLIT_PORT=8501
NEO4J_BROWSER_PORT=7474
NEO4J_BOLT_PORT=7687

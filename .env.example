# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
# Usado apenas pelo container neo4j para definir usuario/senha iniciais (formato user/senha)
NEO4J_AUTH=neo4j/password

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Gemini aceita GOOGLE_API_KEY (preferencial) ou GEMINI_API_KEY.
GOOGLE_API_KEY=
GEMINI_API_KEY=
EXTRACTION_LLM_PROVIDER=anthropic
ANALYSIS_LLM_PROVIDER=anthropic
KG_CLASSIFIER_LLM_PROVIDER=openai
KG_CLASSIFIER_OPENAI_MODEL=gpt-4o-mini
KG_CLASSIFIER_GEMINI_MODEL=gemini-2.5-flash

# --- API ---
ALLOWED_ORIGINS=http://localhost:8501
LOG_LEVEL=INFO

# --- Vision Detector (extração de diagrama, YOLOv8) ---
# URL interna do serviço vision-detector (ver docker-compose.yml). Se ficar
# vazia/removida, extraction/service.py cai no modo de import direto (sem
# Docker) -- ver docstring de extraction/service.py.
VISION_DETECTOR_URL=http://vision-detector:8000

# --- Portas (opcional, defaults abaixo) ---
API_PORT=8000
STREAMLIT_PORT=8501
NEO4J_BROWSER_PORT=7474
NEO4J_BOLT_PORT=7687
VISION_DETECTOR_PORT=8001

# --- Crawler (Épico 2) ---
KG_CRAWL_OUTPUT_DIR=data/crawled
KG_CRAWL_DELAY_S=1.5
KG_CRAWL_REQUEST_TIMEOUT_S=30
# Set to false only if local SSL CA chain fails (e.g. corporate proxy on Windows dev)
KG_CRAWL_SSL_VERIFY=true
